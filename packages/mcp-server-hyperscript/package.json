{
  "name": "@hyperscript-tools/mcp-server",
  "version": "2.8.0",
  "description": "MCP server for original _hyperscript (hyperscript.org): parser-backed validation, parsing, docs, and editor assist for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hyperscript-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:check": "vitest run --reporter=dot"
  },
  "keywords": [
    "mcp",
    "hyperscript",
    "_hyperscript",
    "ai",
    "llm",
    "development-tools",
    "language-server"
  ],
  "author": "hyperscript-tools contributors",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "hyperscript.org": "^0.9.93"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codetalcott/hyperscript-tools.git",
    "directory": "packages/mcp-server-hyperscript"
  },
  "bugs": {
    "url": "https://github.com/codetalcott/hyperscript-tools/issues"
  },
  "homepage": "https://github.com/codetalcott/hyperscript-tools/tree/main/packages/mcp-server-hyperscript#readme"
}
